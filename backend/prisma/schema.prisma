// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model User {
  id           Int          @id @default(autoincrement())
  name         String
  email        String       @unique
  passwordHash String       @map("password_hash")
  roleId       Int          @map("role_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  role         Role         @relation(fields: [roleId], references: [id])
  accounts     Account[]
  loans        Loan[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Account {
  id                   Int                @id @default(autoincrement())
  userId               Int                @map("user_id")
  type                 AccountType
  balance              Decimal            @default(0) @db.Decimal(18, 2)
  interestRate         Decimal?           @map("interest_rate") @db.Decimal(5, 2)
  maturityDate         DateTime?          @map("maturity_date")
  fdPrincipalAmount    Decimal?           @map("fd_principal_amount") @db.Decimal(18, 2)
  fdStatus             FixedDepositStatus? @map("fd_status")
  fdInterestCreditedAt DateTime?          @map("fd_interest_credited_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  user                 User               @relation(fields: [userId], references: [id])
  sentTransactions     Transaction[]      @relation("SenderAccount")
  receivedTransactions Transaction[]      @relation("ReceiverAccount")
  loanRepayments       LoanRepayment[]    @relation("RepaymentPayerAccount")
  disbursedLoans       Loan[]             @relation("LoanDisbursementAccount")

  @@map("accounts")
  @@index([userId, createdAt])
  @@index([type, fdStatus, maturityDate])
}

model Transaction {
  id                Int                 @id @default(autoincrement())
  senderAccountId   Int                 @map("sender_account_id")
  receiverAccountId Int                 @map("receiver_account_id")
  amount            Decimal             @db.Decimal(18, 2)
  status            TransactionStatus   @default(PENDING)
  category          TransactionCategory?
  note              String?             @db.VarChar(240)
  createdAt         DateTime            @default(now()) @map("created_at")
  senderAccount     Account             @relation("SenderAccount", fields: [senderAccountId], references: [id])
  receiverAccount   Account             @relation("ReceiverAccount", fields: [receiverAccountId], references: [id])
  alerts            Alert[]
  loanRepayment     LoanRepayment?

  @@map("transactions")
  @@index([senderAccountId, createdAt])
  @@index([receiverAccountId, createdAt])
  @@index([category, createdAt])
}

model Loan {
  id                  Int             @id @default(autoincrement())
  userId              Int             @map("user_id")
  amount              Decimal         @db.Decimal(18, 2)
  interestRate        Decimal         @map("interest_rate") @db.Decimal(5, 2)
  tenureMonths        Int             @map("tenure_months")
  status              LoanStatus      @default(PENDING)
  emiAmount           Decimal?        @map("emi_amount") @db.Decimal(18, 2)
  outstandingBalance  Decimal?        @map("outstanding_balance") @db.Decimal(18, 2)
  approvedAt          DateTime?       @map("approved_at")
  completedAt         DateTime?       @map("completed_at")
  disbursementAccountId Int?          @map("disbursement_account_id")
  createdAt           DateTime        @default(now()) @map("created_at")
  user                User            @relation(fields: [userId], references: [id])
  disbursementAccount Account?        @relation("LoanDisbursementAccount", fields: [disbursementAccountId], references: [id])
  repayments          LoanRepayment[]

  @@map("loans")
  @@index([userId, status, createdAt])
}

model LoanRepayment {
  id                 Int                 @id @default(autoincrement())
  loanId             Int                 @map("loan_id")
  installmentNumber  Int                 @map("installment_number")
  dueDate            DateTime            @map("due_date")
  amountDue          Decimal             @map("amount_due") @db.Decimal(18, 2)
  principalComponent Decimal             @map("principal_component") @db.Decimal(18, 2)
  interestComponent  Decimal             @map("interest_component") @db.Decimal(18, 2)
  balanceAfter       Decimal             @map("balance_after") @db.Decimal(18, 2)
  status             LoanRepaymentStatus @default(PENDING)
  paidAt             DateTime?           @map("paid_at")
  payerAccountId     Int?                @map("payer_account_id")
  transactionId      Int?                @unique @map("transaction_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  loan               Loan                @relation(fields: [loanId], references: [id])
  payerAccount       Account?            @relation("RepaymentPayerAccount", fields: [payerAccountId], references: [id])
  transaction        Transaction?        @relation(fields: [transactionId], references: [id])

  @@map("loan_repayments")
  @@unique([loanId, installmentNumber])
  @@index([loanId, status, dueDate])
}

model Alert {
  id            Int         @id @default(autoincrement())
  transactionId Int         @map("transaction_id")
  reason        String
  createdAt     DateTime    @default(now()) @map("created_at")
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@map("alerts")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  action    String
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

enum AccountType {
  SAVINGS
  CURRENT
  FD
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum TransactionCategory {
  FOOD
  RENT
  UTILITIES
  GROCERIES
  ENTERTAINMENT
  SHOPPING
  TRAVEL
  HEALTHCARE
  EDUCATION
  SAVINGS
  INVESTMENT
  TRANSFER
  OTHER
  LOAN_REPAYMENT
  LOAN_DISBURSEMENT
  FD_INTEREST
}

enum FixedDepositStatus {
  ACTIVE
  MATURED
}

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  CLOSED
}

enum LoanRepaymentStatus {
  PENDING
  PAID
  OVERDUE
}
