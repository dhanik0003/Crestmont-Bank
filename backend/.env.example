# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/banking_db"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="24h"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS (comma-separated list of allowed origins) ────────────────────────────
# Leave unset in development — defaults to localhost:3000 and localhost:5173
# ALLOWED_ORIGINS="https://your-frontend.com"

# ── Fraud detection ───────────────────────────────────────────────────────────
FRAUD_AMOUNT_THRESHOLD=50000
FRAUD_RAPID_TRANSACTION_LIMIT=5
FRAUD_RAPID_TRANSACTION_WINDOW_MINUTES=10

# ── Fixed deposit scheduler ───────────────────────────────────────────────────
FD_MATURITY_SCAN_INTERVAL_MS=60000
